# Point every data path into the sandbox so nothing touches the real ~/.claude.
env USAGE_CACHE=$WORK/usage-cache.json
env CCPOOL_HISTORY=$WORK/history.jsonl
env CCPOOL_CALIB_CACHE=$WORK/calib.json
env CCPOOL_BLOCKS_CACHE=$WORK/blocks.json
env CCPOOL_STATUSLINE_LOG=$WORK/statusline.log

# status with no snapshots: the warmup guidance, exit 0 (on-demand read, reports rather than errors)
exec ccpool status
stdout 'no data yet'

# check with no snapshots: a non-zero exit, with the warmup message routed to STDERR (the message
# identifies the no-data path; testscript's ! exec only pins the exit as non-zero)
! exec ccpool check
stderr 'No usage snapshots yet'

# prune with nothing to prune: exit 0, reports zero removed
exec ccpool prune
stdout 'pruned 0 stale snapshot'
