# Point every data path into the sandbox so nothing touches the real ~/.ccpool. CCPOOL_HOME is the
# writable store dir (HOME is /no-home here): status/check open an empty DB -> the warm-up path.
env CCPOOL_HOME=$WORK
env CCPOOL_STATUSLINE_LOG=$WORK/statusline.log

# status with no snapshots: the warmup guidance, exit 0 (on-demand read, reports rather than errors)
exec ccpool status
stdout 'no data yet'

# bare `ccpool` (no args) defaults to status -- must NOT panic on an empty argv. Regression: v0.1.0
# crashed here (slice bounds out of range [1:0]) because dispatch sliced args[1:] before length-checking.
exec ccpool
stdout 'no data yet'

# check with no snapshots: a non-zero exit, with the warmup message routed to STDERR (the message
# identifies the no-data path; testscript's ! exec only pins the exit as non-zero)
! exec ccpool check
stderr 'No usage snapshots yet'

# prune with nothing to prune: exit 0, reports zero removed
exec ccpool prune
stdout 'pruned 0 stale snapshot'
