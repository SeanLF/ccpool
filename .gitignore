# ccpool writes its cache/history under ~/.claude, not here.
*.gem
.DS_Store
scratch/
# Go build output
/ccpool
/dist/
# staged fixture data for the demo GIFs (regenerated by demo/setup.sh)
demo/.data/

# rapid property-test failure repro seeds (transient)
testdata/rapid/

# subagent-driven-development scratch
.superpowers/

# ~/.gitignore_global has `ENV/` (Python venv); on macOS core.ignorecase=true it matches
# internal/env/ and silently drops the package from `git add`. Re-include it explicitly so a new
# file there can't vanish from commits again.
!internal/env/
