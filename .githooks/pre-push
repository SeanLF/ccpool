#!/bin/sh
# Local gate: run the full Go check before every push. Enable once with:
#   git config core.hooksPath .githooks
# Skip a one-off push with `git push --no-verify`.
#
# Zero-dep by design: a committed POSIX hook needs nothing installed beyond the Go toolchain,
# matching ccpool's resist-frameworks ethos (no lefthook).
set -e

here="$(cd "$(dirname "$0")/.." && pwd)"
cd "$here"

echo "pre-push: make check"
make check
